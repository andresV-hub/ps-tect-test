<h2><%= t("defaults.update_account_title", resource: resource_name.to_s.humanize) %></h2>

<%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :email,
                required: true,
                autofocus: true,
                label: t("defaults.email") %>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p>Actualmente esperando confirmación de: <%= resource.unconfirmed_email %></p>
    <% end %>

    <%= f.input :password,
                required: false,
                label: t("defaults.password"),
                hint: t("defaults.password_leave_blank_hint"),
                input_html: { autocomplete: "new-password" } %>
    <%= f.input :password_confirmation,
                required: false,
                label: t("defaults.password_confirmation"),
                input_html: { autocomplete: "new-password" } %>
    <%= f.input :current_password,
                required: true,
                label: t("defaults.current_password"),
                hint: t("defaults.current_password_hint"),
                input_html: { autocomplete: "current-password" } %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, t("defaults.update") %>
  </div>
<% end %>

<h3><%= t("defaults.cancel_account_title") %></h3>

<div>
  ¿No estás satisfecho?
  <%= button_to t("defaults.cancel_account_button"),
                registration_path(resource_name),
                method: :delete,
                data: { confirm: t("defaults.cancel_account_confirm"), turbo_confirm: t("defaults.cancel_account_confirm") } %>
</div>

<%= link_to t("defaults.back"), :back %>
